# ==============================================================================
# ARViz Environment Variables Configuration Template
# Rename this file to '.env' and place it in the backend/ directory.
# ==============================================================================

# Flask Environment Configuration
FLASK_ENV=production
SECRET_KEY=super-secret-jwt-signing-key-change-in-production

# MongoDB Connection Parameters
# - For local MongoDB, use: mongodb://localhost:27017/
# - For MongoDB Atlas, paste your connection string below:
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=arviz

# Server Port Selection (Cloud deployment platforms like Heroku/Render populate this automatically)
PORT=5000
